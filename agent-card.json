{
  "name": "optimobile",
  "description": "Mobile analytics (FLIP — Firebase/Crashlytics dominate).",
  "url": "https://optimobile.ai",
  "version": "0.1.0",
  "provider": {
    "organization": "CSOAI-ORG",
    "url": "https://csoai.org"
  },
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "stateTransitionHistory": true
  },
  "defaultInputModes": [
    "text"
  ],
  "defaultOutputModes": [
    "text",
    "json"
  ],
  "skills": [
    {
      "id": "a2a-mesh",
      "name": "Cross-hive A2A call",
      "description": "Can call other MEOK hives via A2A (with user consent)"
    },
    {
      "id": "memoria-commit",
      "name": "Versioned memory commit",
      "description": "Commits to memoria namespace 'optimobile'"
    }
  ],
  "securitySchemes": {
    "oauth2": {
      "type": "oauth2",
      "flows": {
        "authorizationCode": {
          "authorizationUrl": "https://optimobile.ai/oauth/authorize",
          "tokenUrl": "https://optimobile.ai/oauth/token",
          "scopes": {
            "read": "Read hive state",
            "write": "Invoke tools (x402-metered)",
            "audit": "Read audit trail"
          }
        }
      }
    }
  },
  "x402Pricing": {
    "enabled": false,
    "currency": "USD",
    "amount": "0.00",
    "freeCallsPerIPPerDay": "10"
  }
}
